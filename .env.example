HF_TOKEN=your_huggingface_token_here
WANDB_API_KEY=your_wandb_key_here  # optional, for experiment tracking

# Model to fine-tune (smaller = faster, good for demo)
BASE_MODEL=microsoft/phi-2
# Other options:
# mistralai/Mistral-7B-v0.1  (needs GPU)
# TinyLlama/TinyLlama-1.1B-Chat-v1.0  (CPU friendly)

# Training config
MAX_STEPS=100
BATCH_SIZE=4
LEARNING_RATE=2e-4
LORA_R=16
LORA_ALPHA=32
